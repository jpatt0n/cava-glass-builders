---
import { audiences, serviceArea } from "../data/site";
---

<section id="who" class="relative bg-[var(--color-ink)] py-24 md:py-32 lg:py-40">
  <div class="mx-auto max-w-7xl px-6 lg:px-10">
    <div class="reveal max-w-3xl">
      <p class="flex items-center gap-4 text-xs uppercase tracking-luxe text-[var(--color-bone-muted)]">
        <span class="hairline"></span>
        Who We Serve
      </p>
      <h2 class="mt-6 font-display text-4xl leading-tight md:text-6xl">
        Built for the trade. Refined for the home.
      </h2>
    </div>

    <div class="mt-16 grid gap-px bg-[var(--color-ink-line)] md:grid-cols-3">
      {audiences.map((a, i) => (
        <div class="reveal bg-[var(--color-ink)] p-8 md:p-10" style={`transition-delay:${i * 80}ms`}>
          <p class="font-display text-2xl text-[var(--color-bone)] md:text-3xl">
            {a.title}
          </p>
          <p class="mt-5 text-sm leading-relaxed text-[var(--color-bone-muted)]">
            {a.body}
          </p>
        </div>
      ))}
    </div>

    <!-- Service-area marquee -->
    <div class="reveal mt-20 border-t border-[var(--color-ink-line)] pt-10">
      <p class="text-xs uppercase tracking-luxe text-[var(--color-bone-muted)]">
        Service Area
      </p>
      <ul class="mt-6 flex flex-wrap gap-x-6 gap-y-3 text-sm text-[var(--color-bone)]/85">
        {serviceArea.map((n) => (
          <li class="flex items-center gap-3">
            <span class="h-1 w-1 rounded-full bg-[var(--color-steel)]"></span>
            {n}
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>
