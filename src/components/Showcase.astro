---
import { Picture } from "astro:assets";
import { showcase } from "../data/site";

type ImageMetadata = import("astro").ImageMetadata;
const imageModules = import.meta.glob<{ default: ImageMetadata }>(
  "../assets/projects/*.{jpg,jpeg,png,webp,avif}",
  { eager: true },
);
function imgFor(name: string): ImageMetadata {
  const match = Object.entries(imageModules).find(([k]) => k.includes(`/${name}.`));
  if (!match) throw new Error(`Image not found: ${name}`);
  return match[1].default;
}

// Asymmetric grid: alternating sizes for editorial feel
const layout = [
  "md:col-span-7 md:row-span-2",
  "md:col-span-5",
  "md:col-span-5",
  "md:col-span-6",
  "md:col-span-6",
  "md:col-span-4",
  "md:col-span-4",
  "md:col-span-4",
  "md:col-span-7",
  "md:col-span-5",
];
---

<section id="work" class="relative bg-[var(--color-ink-soft)] py-24 md:py-32 lg:py-40">
  <div class="mx-auto max-w-7xl px-6 lg:px-10">
    <div class="reveal flex flex-col items-start justify-between gap-6 md:flex-row md:items-end">
      <div class="max-w-2xl">
        <p class="flex items-center gap-4 text-xs uppercase tracking-luxe text-[var(--color-bone-muted)]">
          <span class="hairline"></span>
          Selected Work
        </p>
        <h2 class="mt-6 font-display text-4xl leading-tight md:text-6xl">
          Frameless glass in Houston homes.
        </h2>
      </div>
      <p class="max-w-md text-sm leading-relaxed text-[var(--color-bone-muted)]">
        A small selection of recent installations across the Greater Houston
        area — from spa-style primary baths to wine-room enclosures.
      </p>
    </div>

    <div class="mt-14 grid grid-cols-1 gap-3 md:grid-cols-12 md:gap-4">
      {showcase.map((item, i) => (
        <figure
          class={`reveal group relative overflow-hidden bg-[var(--color-ink)] ${layout[i] ?? "md:col-span-4"}`}
          style={`transition-delay:${(i % 5) * 60}ms`}
        >
          <div class="relative aspect-[4/3] md:aspect-auto md:h-full md:min-h-[260px]">
            <Picture
              src={imgFor(item.image)}
              alt={item.alt}
              widths={[480, 720, 960, 1280]}
              sizes="(min-width: 768px) 50vw, 100vw"
              formats={["avif", "webp"]}
              quality={70}
              pictureAttributes={{ class: "block h-full w-full" }}
              class="h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.04]"
            />
            <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-[rgba(11,13,16,0.75)] via-transparent to-transparent opacity-90 transition-opacity group-hover:opacity-100"></div>
            <figcaption class="absolute bottom-0 left-0 p-5 text-xs uppercase tracking-luxe text-[var(--color-bone)]">
              {item.category}
            </figcaption>
          </div>
        </figure>
      ))}
    </div>
  </div>
</section>
