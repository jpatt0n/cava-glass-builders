---
import { stats } from "../data/site";
---

<section
  class="relative isolate overflow-hidden bg-[var(--color-ink)] py-16 md:py-20"
>
  <div class="absolute inset-x-0 top-0 h-px bg-[var(--color-ink-line)]"></div>
  <div class="absolute inset-x-0 bottom-0 h-px bg-[var(--color-ink-line)]"></div>

  <div class="mx-auto max-w-7xl px-6 lg:px-10">
    <ul class="grid grid-cols-2 gap-y-10 md:grid-cols-4 md:gap-y-0">
      {stats.map((s) => (
        <li class="reveal text-center md:text-left">
          <p class="font-display text-4xl text-[var(--color-bone)] md:text-5xl">
            {s.value}
          </p>
          <p class="mt-2 text-xs uppercase tracking-luxe text-[var(--color-bone-muted)]">
            {s.label}
          </p>
        </li>
      ))}
    </ul>
  </div>
</section>
