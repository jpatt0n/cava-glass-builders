---
import { site } from "../data/site";
---

<header
  id="site-header"
  class="fixed inset-x-0 top-0 z-50 transition-colors duration-300 bg-transparent"
>
  <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-5 lg:px-10">
    <a href="#top" class="flex items-center gap-3" aria-label={site.name}>
      <img
        src="/logo-cava-white.svg"
        alt={site.name}
        class="h-9 w-auto md:h-10"
        width="180"
        height="44"
      />
    </a>

    <nav class="hidden items-center gap-10 md:flex">
      <a href="#services" class="nav-link">Services</a>
      <a href="#work" class="nav-link">Work</a>
      <a href="#about" class="nav-link">About</a>
      <a href="#contact" class="nav-link">Contact</a>
    </nav>

    <a
      href="#contact"
      class="hidden md:inline-flex items-center gap-2 border border-[var(--color-bone)] px-5 py-2.5 text-xs uppercase tracking-luxe text-[var(--color-bone)] transition hover:bg-[var(--color-bone)] hover:text-[var(--color-ink)]"
    >
      Request a Quote
    </a>

    <!-- Mobile menu button -->
    <button
      id="menu-toggle"
      type="button"
      class="md:hidden inline-flex h-10 w-10 items-center justify-center text-[var(--color-bone)]"
      aria-label="Open menu"
      aria-expanded="false"
    >
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M3 7h18M3 12h18M3 17h18" stroke-linecap="round" />
      </svg>
    </button>
  </div>

  <!-- Mobile drawer -->
  <div
    id="mobile-menu"
    class="hidden border-t border-[var(--color-ink-line)] bg-[var(--color-ink)] md:hidden"
  >
    <nav class="flex flex-col px-6 py-6 text-base">
      <a href="#services" class="py-3 nav-link-mobile">Services</a>
      <a href="#work" class="py-3 nav-link-mobile">Work</a>
      <a href="#about" class="py-3 nav-link-mobile">About</a>
      <a href="#contact" class="py-3 nav-link-mobile">Contact</a>
      <a
        href="#contact"
        class="mt-4 inline-flex items-center justify-center border border-[var(--color-bone)] px-5 py-3 text-xs uppercase tracking-luxe"
      >
        Request a Quote
      </a>
    </nav>
  </div>
</header>

<style>
  .nav-link {
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: var(--color-bone);
    opacity: 0.85;
    transition: opacity 0.2s ease;
  }
  .nav-link:hover { opacity: 1; }

  .nav-link-mobile {
    text-transform: uppercase;
    letter-spacing: 0.22em;
    font-size: 0.85rem;
    border-bottom: 1px solid var(--color-ink-line);
  }

  #site-header.is-scrolled {
    background-color: rgba(11, 13, 16, 0.85);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--color-ink-line);
  }
</style>

<script>
  const header = document.getElementById("site-header");
  const setScrolled = () => {
    if (!header) return;
    if (window.scrollY > 30) header.classList.add("is-scrolled");
    else header.classList.remove("is-scrolled");
  };
  setScrolled();
  window.addEventListener("scroll", setScrolled, { passive: true });

  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");
  toggle?.addEventListener("click", () => {
    const open = menu?.classList.toggle("hidden") === false;
    toggle.setAttribute("aria-expanded", String(open));
  });
  menu?.querySelectorAll("a").forEach((a) =>
    a.addEventListener("click", () => {
      menu.classList.add("hidden");
      toggle?.setAttribute("aria-expanded", "false");
    }),
  );
</script>
