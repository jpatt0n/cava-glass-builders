---
import { Picture } from "astro:assets";
import { services } from "../data/site";

// Eagerly import all project images so we can resolve them by name from data
const imageModules = import.meta.glob<{ default: ImageMetadata }>(
  "../assets/projects/*.{jpg,jpeg,png,webp,avif}",
  { eager: true },
);

type ImageMetadata = import("astro").ImageMetadata;

function imgFor(name: string): ImageMetadata {
  const match = Object.entries(imageModules).find(([k]) => k.includes(`/${name}.`));
  if (!match) throw new Error(`Image not found: ${name}`);
  return match[1].default;
}
---

<section id="services" class="relative bg-[var(--color-ink)] py-24 md:py-32 lg:py-40">
  <div class="mx-auto max-w-7xl px-6 lg:px-10">
    <div class="reveal max-w-3xl">
      <p class="flex items-center gap-4 text-xs uppercase tracking-luxe text-[var(--color-bone-muted)]">
        <span class="hairline"></span>
        Our Services
      </p>
      <h2 class="mt-6 font-display text-4xl leading-tight md:text-6xl">
        Crafted glass for every surface.
      </h2>
      <p class="mt-6 max-w-2xl text-base leading-relaxed text-[var(--color-bone-muted)] md:text-lg">
        From frameless showers to architectural partitions, we fabricate and
        install to the tolerances builders and designers expect.
      </p>
    </div>

    <div class="mt-16 grid gap-6 md:gap-8 lg:grid-cols-3">
      {services.map((svc, i) => (
        <article
          class="reveal group relative overflow-hidden border border-[var(--color-ink-line)] bg-[var(--color-ink-soft)]"
          style={`transition-delay:${i * 80}ms`}
        >
          <div class="relative aspect-[4/3] overflow-hidden">
            <Picture
              src={imgFor(svc.image)}
              alt={svc.title}
              widths={[480, 720, 960, 1200]}
              sizes="(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw"
              formats={["avif", "webp"]}
              quality={70}
              pictureAttributes={{ class: "block h-full w-full" }}
              class="h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-105"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-[rgba(11,13,16,0.85)] via-transparent to-transparent"></div>
          </div>

          <div class="p-7 md:p-8">
            <p class="text-xs uppercase tracking-luxe text-[var(--color-steel)]">
              0{services.indexOf(svc) + 1}
            </p>
            <h3 class="mt-3 font-display text-3xl">{svc.title}</h3>
            <p class="mt-4 text-sm leading-relaxed text-[var(--color-bone-muted)]">
              {svc.summary}
            </p>
            <ul class="mt-6 space-y-2">
              {svc.bullets.map((b) => (
                <li class="flex items-start gap-3 text-sm text-[var(--color-bone)]/85">
                  <span class="mt-2 h-px w-3 shrink-0 bg-[var(--color-steel)]"></span>
                  {b}
                </li>
              ))}
            </ul>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
