{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "cava-glass-builders",
  "main": "worker/index.ts",
  "compatibility_date": "2026-05-03",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "404-page"
  },
  "observability": {
    "enabled": true
  }
}
